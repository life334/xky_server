<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xakcch.project.mapper.ProjCategoryMapper">

    <resultMap type="ProjCategory" id="ProjCategoryResult">
        <id     property="id"             column="id"               />
        <result property="parentId"       column="parent_id"        />
        <result property="name"           column="name"             />
        <result property="level"          column="level"            />
        <result property="internalPrice"  column="internal_price"   />
        <result property="externalPrice"  column="external_price"   />
        <result property="sortOrder"      column="sort_order"       />
        <result property="status"         column="status"           />
        <result property="delFlag"        column="del_flag"         />
        <result property="parentName"     column="parent_name"      />
        <result property="createBy"       column="create_by"        />
        <result property="createTime"     column="create_time"      />
        <result property="updateBy"       column="update_by"        />
        <result property="updateTime"     column="update_time"      />
        <result property="remark"         column="remark"           />
    </resultMap>

    <sql id="selectCategoryVo">
        select c.id, c.parent_id, c.name, c.level, c.internal_price, c.external_price,
               c.sort_order, c.status, c.del_flag, c.create_by, c.create_time
        from proj_category c
    </sql>

    <select id="selectCategoryList" parameterType="ProjCategory" resultMap="ProjCategoryResult">
        <include refid="selectCategoryVo"/>
        where c.del_flag = '0'
        <if test="name != null and name != ''">
            AND c.name like concat('%', #{name}, '%')
        </if>
        <if test="level != null">
            AND c.level = #{level}
        </if>
        <if test="status != null and status != ''">
            AND c.status = #{status}
        </if>
        order by c.parent_id, c.sort_order
    </select>

    <select id="selectCategoryById" parameterType="Long" resultMap="ProjCategoryResult">
        select c.id, c.parent_id, c.name, c.level, c.internal_price, c.external_price,
               c.sort_order, c.status, c.del_flag, c.create_by, c.create_time,
               (select name from proj_category where id = c.parent_id) as parent_name
        from proj_category c
        where c.id = #{id}
    </select>

    <select id="hasChildByCategoryId" parameterType="Long" resultType="int">
        select count(1) from proj_category
        where del_flag = '0' and parent_id = #{id} limit 1
    </select>

    <select id="checkCategoryNameUnique" parameterType="ProjCategory" resultMap="ProjCategoryResult">
        <include refid="selectCategoryVo"/>
        where c.name = #{name} and c.parent_id = #{parentId} and c.del_flag = '0' limit 1
    </select>

    <select id="checkCategoryUsedByProject" parameterType="Long" resultType="int">
        select count(1) from proj_project
        where project_category_id = #{id} and del_flag = '0'
    </select>

    <insert id="insertCategory" parameterType="ProjCategory">
        insert into proj_category(
            <if test="parentId != null">parent_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="level != null">level,</if>
            <if test="internalPrice != null">internal_price,</if>
            <if test="externalPrice != null">external_price,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="parentId != null">#{parentId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="level != null">#{level},</if>
            <if test="internalPrice != null">#{internalPrice},</if>
            <if test="externalPrice != null">#{externalPrice},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            now()
        )
    </insert>

    <update id="updateCategory" parameterType="ProjCategory">
        update proj_category
        <set>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="level != null">level = #{level},</if>
            <if test="internalPrice != null">internal_price = #{internalPrice},</if>
            <if test="externalPrice != null">external_price = #{externalPrice},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = now()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteCategoryById" parameterType="Long">
        update proj_category set del_flag = '2' where id = #{id}
    </delete>

    <delete id="deleteCategoryByIds" parameterType="Long">
        update proj_category set del_flag = '2' where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
